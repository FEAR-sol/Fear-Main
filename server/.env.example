# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/fear-db

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
# IMPORTANT: FROM_EMAIL domain must be verified in your Resend dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=newsletter@yourdomain.com
FROM_NAME=FEAR Studio

# ─── Security ─────────────────────────────────────────────────────────────────
# Used to protect POST /api/notify — keep this secret
ADMIN_API_KEY=your-secret-admin-key-here

# ─── Frontend URL ─────────────────────────────────────────────────────────────
# Used in email links and CORS. Change to your production domain when deploying.
CLIENT_URL=http://localhost:3000
